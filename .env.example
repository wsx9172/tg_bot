# Copy to `.env` and fill in. `.env` must not be committed.

# Telegram BotFather
TELEGRAM_BOT_TOKEN=
# webhook or polling
BOT_MODE=webhook
# Comma-separated Telegram user IDs allowed to use the bot (required for any access)
ALLOWED_USERS=

# Telegram webhook
WEBHOOK_DOMAIN=bot.domain
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=33333
# Optional: defaults to TELEGRAM_BOT_TOKEN when empty
WEBHOOK_URL_PATH=
# Optional: sent as X-Telegram-Bot-Api-Secret-Token
WEBHOOK_SECRET_TOKEN=

# 与 DB channel.platform、command_allow 等作用域一致；接入飞书/企微等时改为对应标识
CHAT_PLATFORM=telegram
# 与 bot_instance.id 一致，用于审计与白名单匹配
BOT_INSTANCE_ID=1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=telegram_bot
# 可选：秒
# MYSQL_CONNECT_TIMEOUT=10
# MYSQL_READ_TIMEOUT=30
# MYSQL_WRITE_TIMEOUT=30

NODE_ID=1

CPU_ALERT=85
MEM_ALERT=85
DISK_ALERT=90

# =========================
# 日志配置
# =========================
# 日志级别：DEBUG, INFO, WARNING, ERROR（默认 INFO）
LOG_LEVEL=INFO
# 是否启用 SQL 日志：true/false（默认 false）
LOG_SQL=false


OPENAI_API_KEY=
OPENAI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=deepseek-v4-pro
# 可选：对应 llm_provider.id，写入 llm_log.provider_id
DEFAULT_LLM_PROVIDER_ID=

# =========================
# LLM 工具调用配置
# =========================
# 启用的工具类型集合（逗号分隔），可选值：search, system
ENABLED_TOOLS=search,system

# 搜索引擎配置
SEARCH_BASE_URL=

# =========================
# LLM 对话历史与工具调用限制配置
# =========================
# 对话历史轮次数量（从数据库加载的最近 N 轮对话）
MEMORY_TURNS=0

# 单条历史消息最大字符数（超过则截断）
MAX_HISTORY_TEXT_LENGTH=2000

# 工具返回内容最大字符数（超过则截断，防止 Context 爆炸）
MAX_TOOL_CONTENT=4000

# 搜索结果摘要最大长度（单个 snippet 的最大字符数）
MAX_SNIPPET_LENGTH=300

# 工具调用最大轮次（防止无限 Tool Loop）
MAX_TOOL_CALL_ROUNDS=5
