# Copy to `.env` and fill in. `.env` must not be committed.

# Telegram BotFather
TELEGRAM_BOT_TOKEN=
# webhook or polling
BOT_MODE=webhook
# Comma-separated Telegram user IDs allowed to use the bot (required for any access)
ALLOWED_USERS=

# Telegram webhook
WEBHOOK_DOMAIN=bot.domain
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=33333
# Optional: defaults to TELEGRAM_BOT_TOKEN when empty
WEBHOOK_URL_PATH=
# Optional: sent as X-Telegram-Bot-Api-Secret-Token
WEBHOOK_SECRET_TOKEN=

# 与 DB channel.platform、command_allow 等作用域一致；接入飞书/企微等时改为对应标识
CHAT_PLATFORM=telegram
# 与 bot_instance.id 一致，用于审计与白名单匹配
BOT_INSTANCE_ID=1

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=
MYSQL_USER=tg_bot
MYSQL_PASSWORD=
MYSQL_DATABASE=telegram_bot
# 可选：秒
# MYSQL_CONNECT_TIMEOUT=10
# MYSQL_READ_TIMEOUT=30
# MYSQL_WRITE_TIMEOUT=30

NODE_ID=1

CPU_ALERT=85
MEM_ALERT=85
DISK_ALERT=90

OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
# 可选：对应 llm_provider.id，写入 llm_log.provider_id
DEFAULT_LLM_PROVIDER_ID=
